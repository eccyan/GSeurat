{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/eccyan/GSeurat/schemas/scene.schema.json",
  "title": "GSeurat Scene",
  "description": "Scene file format for the GSeurat engine (v2)",
  "type": "object",
  "required": ["version"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 2,
      "description": "Scene format version"
    },
    "ambient_color": {
      "$ref": "#/definitions/color4",
      "description": "Global ambient light color [r, g, b, a]"
    },
    "god_rays_intensity": {
      "type": "number",
      "minimum": 0,
      "description": "God rays volumetric light intensity (0 = off)"
    },
    "lights": {
      "type": "array",
      "items": { "$ref": "#/definitions/light" },
      "description": "Static scene lights (max 8)"
    },
    "player": {
      "$ref": "#/definitions/player",
      "description": "Player spawn configuration"
    },
    "game_objects": {
      "type": "array",
      "items": { "$ref": "#/definitions/game_object" },
      "description": "Unified game objects (replaces legacy npcs[] and objects[])"
    },
    "portals": {
      "type": "array",
      "items": { "$ref": "#/definitions/portal" }
    },
    "particle_emitters": {
      "type": "array",
      "items": { "$ref": "#/definitions/particle_emitter" },
      "description": "Gaussian particle emitters"
    },
    "animations": {
      "type": "array",
      "items": { "$ref": "#/definitions/animation" },
      "description": "Gaussian animation effects on scene regions"
    },
    "vfx_instances": {
      "type": "array",
      "items": { "$ref": "#/definitions/vfx_instance" },
      "description": "Placed VFX preset instances (authored in Méliès)"
    },
    "gaussian_splat": {
      "$ref": "#/definitions/gaussian_splat",
      "description": "3D Gaussian Splatting configuration"
    },
    "collision": {
      "$ref": "#/definitions/collision_grid"
    },
    "weather": {
      "$ref": "#/definitions/weather"
    },
    "day_night": {
      "$ref": "#/definitions/day_night"
    },
    "background_layers": {
      "type": "array",
      "items": { "$ref": "#/definitions/background_layer" }
    },
    "torch_emitter": { "$ref": "#/definitions/emitter_config_2d" },
    "torch_positions": {
      "type": "array",
      "items": { "$ref": "#/definitions/vec3" },
      "description": "Torch light positions [x, y, z]"
    },
    "torch_audio_positions": {
      "type": "array",
      "items": { "$ref": "#/definitions/vec3" }
    },
    "footstep_emitter": { "$ref": "#/definitions/emitter_config_2d" },
    "npc_aura_emitter": { "$ref": "#/definitions/emitter_config_2d" },
    "nav_zones": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Navigation zone names (index 0 = default)"
    },
    "tilemap": { "type": "object" },
    "tile_animations": { "type": "array" }
  },
  "additionalProperties": false,
  "definitions": {
    "vfx_instance": {
      "type": "object",
      "required": ["vfx_file", "position"],
      "properties": {
        "vfx_file": {
          "type": "string",
          "description": "Path to .vfx.json preset file (relative to assets)"
        },
        "position": {
          "$ref": "#/definitions/vec3",
          "description": "World position [x, y, z]"
        },
        "radius": {
          "type": "number",
          "minimum": 0,
          "description": "Area-of-effect radius for GS animation layers"
        },
        "trigger": {
          "type": "string",
          "enum": ["auto", "event"],
          "description": "auto = always active, event = triggered by game logic"
        },
        "loop": {
          "type": "boolean",
          "description": "Repeat after duration ends"
        },
        "rotation_y": {
          "type": "number",
          "description": "Y-axis rotation in degrees (turntable orientation)"
        }
      },
      "additionalProperties": false
    },
    "vec2": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2
    },
    "vec3": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3
    },
    "color3": {
      "type": "array",
      "items": { "type": "number", "minimum": 0, "maximum": 1 },
      "minItems": 3,
      "maxItems": 3
    },
    "color4": {
      "type": "array",
      "items": { "type": "number", "minimum": 0, "maximum": 1 },
      "minItems": 4,
      "maxItems": 4
    },
    "direction": {
      "type": "string",
      "enum": ["up", "down", "left", "right"]
    },
    "light": {
      "type": "object",
      "required": ["position", "radius", "color", "intensity"],
      "properties": {
        "position": { "$ref": "#/definitions/vec3", "description": "Light position [x, y, z]" },
        "radius": { "type": "number", "minimum": 0 },
        "color": { "$ref": "#/definitions/color3" },
        "intensity": { "type": "number", "minimum": 0 },
        "direction": { "$ref": "#/definitions/vec3", "description": "Spot light direction (normalized)" },
        "cone_angle": { "type": "number", "minimum": 1, "maximum": 179, "description": "Spot light cone angle in degrees" },
        "area_width": { "type": "number", "minimum": 0 },
        "area_height": { "type": "number", "minimum": 0 },
        "area_normal": { "$ref": "#/definitions/vec2", "description": "Area light face direction [x, z]" }
      },
      "additionalProperties": false
    },
    "player": {
      "type": "object",
      "properties": {
        "position": { "$ref": "#/definitions/vec3" },
        "tint": { "$ref": "#/definitions/color4" },
        "facing": { "$ref": "#/definitions/direction" },
        "character_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "game_object": {
      "type": "object",
      "required": ["id", "name", "position"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "position": { "$ref": "#/definitions/vec3" },
        "rotation": { "$ref": "#/definitions/vec3" },
        "scale": { "type": "number", "default": 1.0 },
        "ply_file": { "type": "string" },
        "components": {
          "type": "object",
          "additionalProperties": { "type": "object" }
        }
      },
      "additionalProperties": false
    },
    "portal": {
      "type": "object",
      "required": ["position", "size", "target_scene"],
      "properties": {
        "position": { "$ref": "#/definitions/vec3", "description": "Portal position [x, y, z]" },
        "size": { "$ref": "#/definitions/vec2" },
        "target_scene": { "type": "string" },
        "spawn_position": { "$ref": "#/definitions/vec3" },
        "spawn_facing": { "$ref": "#/definitions/direction" }
      },
      "additionalProperties": false
    },
    "particle_emitter": {
      "type": "object",
      "required": ["position"],
      "properties": {
        "preset": { "type": "string", "enum": ["dust_puff", "spark_shower", "magic_spiral", "fire", "smoke", "rain", "snow", "leaves", "fireflies", "steam", "waterfall_mist"] },
        "position": { "$ref": "#/definitions/vec3" },
        "spawn_rate": { "type": "number", "minimum": 0 },
        "lifetime_min": { "type": "number", "minimum": 0 },
        "lifetime_max": { "type": "number", "minimum": 0 },
        "velocity_min": { "$ref": "#/definitions/vec3" },
        "velocity_max": { "$ref": "#/definitions/vec3" },
        "acceleration": { "$ref": "#/definitions/vec3" },
        "color_start": { "$ref": "#/definitions/color3" },
        "color_end": { "$ref": "#/definitions/color3" },
        "scale_min": { "$ref": "#/definitions/vec3" },
        "scale_max": { "$ref": "#/definitions/vec3" },
        "scale_end_factor": { "type": "number" },
        "opacity_start": { "type": "number", "minimum": 0, "maximum": 1 },
        "opacity_end": { "type": "number", "minimum": 0, "maximum": 1 },
        "emission": { "type": "number", "minimum": 0 },
        "region": {
          "type": "object",
          "description": "Spawn region (sphere or box). Replaces spawn_offset_min/max.",
          "properties": {
            "shape": { "type": "string", "enum": ["sphere", "box"] },
            "center": { "$ref": "#/definitions/vec3" },
            "radius": { "type": "number", "minimum": 0 },
            "half_extents": { "$ref": "#/definitions/vec3" }
          },
          "additionalProperties": false
        },
        "spawn_offset_min": { "$ref": "#/definitions/vec3", "description": "Deprecated: use region instead" },
        "spawn_offset_max": { "$ref": "#/definitions/vec3", "description": "Deprecated: use region instead" },
        "burst_duration": { "type": "number", "minimum": 0 },
        "spline": {
          "type": "object",
          "description": "Optional spline path for emitter movement or particle flight",
          "required": ["mode", "control_points"],
          "properties": {
            "mode": { "type": "string", "enum": ["emitter_path", "particle_path"] },
            "control_points": {
              "type": "array",
              "items": { "$ref": "#/definitions/vec3" },
              "minItems": 2,
              "description": "3D control points in local space (minimum 2)"
            },
            "emitter_speed": { "type": "number", "minimum": 0, "description": "Cycles/sec along spline (emitter_path)" },
            "path_spread": { "type": "number", "minimum": 0, "description": "Lateral offset from spline (particle_path)" },
            "align_to_tangent": { "type": "boolean", "description": "Orient particles along spline tangent" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "easing": {
      "type": "string",
      "enum": [
        "linear",
        "in_quad", "out_quad", "in_out_quad",
        "in_cubic", "out_cubic", "in_out_cubic",
        "in_quart", "out_quart", "in_out_quart",
        "in_quint", "out_quint", "in_out_quint",
        "in_sine", "out_sine", "in_out_sine",
        "in_expo", "out_expo", "in_out_expo",
        "in_circ", "out_circ", "in_out_circ",
        "in_back", "out_back", "in_out_back",
        "in_elastic", "out_elastic", "in_out_elastic",
        "in_bounce", "out_bounce", "in_out_bounce",
        "ease_in", "ease_out", "ease_in_out"
      ],
      "description": "Easing curve (see easings.net). Format: {direction}_{type}. Aliases: ease_in=in_quad, ease_out=out_quad, ease_in_out=in_out_quad"
    },
    "animation_params": {
      "type": "object",
      "description": "Lifetime-centric parameters. All describe targets at end of lifetime with optional per-parameter easing.",
      "properties": {
        "rotations": { "type": "number", "description": "Full rotations over lifetime (Orbit, Vortex)" },
        "rotations_easing": { "$ref": "#/definitions/easing" },
        "expansion": { "type": "number", "description": "Radius multiplier at end (1=no change, 2=double)" },
        "expansion_easing": { "$ref": "#/definitions/easing" },
        "height_rise": { "type": "number", "description": "Total Y offset at end (units)" },
        "height_easing": { "$ref": "#/definitions/easing" },
        "opacity_end": { "type": "number", "minimum": 0, "maximum": 1, "description": "Opacity at end (0=gone, 1=unchanged)" },
        "opacity_easing": { "$ref": "#/definitions/easing" },
        "scale_end": { "type": "number", "minimum": 0, "maximum": 1, "description": "Scale at end (0=vanish, 1=unchanged)" },
        "scale_easing": { "$ref": "#/definitions/easing" },
        "velocity": { "type": "number", "description": "Initial velocity magnitude (Detach, Float, Scatter)" },
        "gravity": { "$ref": "#/definitions/vec3", "description": "Physics gravity (Detach, Scatter)" },
        "noise": { "type": "number", "description": "Wander/drift amplitude (Float, Dissolve, Wave)" },
        "wave_speed": { "type": "number", "description": "Wave propagation speed (Wave)" },
        "pulse_frequency": { "type": "number", "description": "Oscillation frequency (Pulse)" }
      },
      "additionalProperties": false
    },
    "animation_reform": {
      "type": "object",
      "description": "Auto-restore Gaussians to original positions after effect finishes",
      "properties": {
        "lifetime": { "type": "number", "minimum": 0, "description": "Reform duration in seconds" }
      },
      "additionalProperties": false
    },
    "animation": {
      "type": "object",
      "required": ["effect", "region"],
      "properties": {
        "effect": { "type": "string", "enum": ["detach", "float", "orbit", "dissolve", "reform", "pulse", "vortex", "wave", "scatter"] },
        "region": {
          "type": "object",
          "required": ["shape", "center"],
          "properties": {
            "shape": { "type": "string", "enum": ["sphere", "box"] },
            "center": { "$ref": "#/definitions/vec3" },
            "radius": { "type": "number", "minimum": 0 },
            "half_extents": { "$ref": "#/definitions/vec3" }
          },
          "additionalProperties": false
        },
        "lifetime": { "type": "number", "minimum": 0 },
        "loop": { "type": "boolean" },
        "params": { "$ref": "#/definitions/animation_params" },
        "reform": { "$ref": "#/definitions/animation_reform" }
      },
      "additionalProperties": false
    },
    "gaussian_splat": {
      "type": "object",
      "required": ["ply_file"],
      "properties": {
        "ply_file": { "type": "string" },
        "camera": {
          "type": "object",
          "properties": {
            "position": { "$ref": "#/definitions/vec3" },
            "target": { "$ref": "#/definitions/vec3" },
            "fov": { "type": "number" }
          }
        },
        "render_width": { "type": "integer" },
        "render_height": { "type": "integer" },
        "scale_multiplier": { "type": "number" },
        "background_image": { "type": "string" },
        "parallax": {
          "type": "object",
          "properties": {
            "azimuth_range": { "type": "number" },
            "elevation_min": { "type": "number" },
            "elevation_max": { "type": "number" },
            "distance_range": { "type": "number" },
            "parallax_strength": { "type": "number" }
          }
        }
      },
      "additionalProperties": false
    },
    "collision_grid": {
      "type": "object",
      "required": ["width", "height", "cell_size"],
      "properties": {
        "width": { "type": "integer" },
        "height": { "type": "integer" },
        "cell_size": { "type": "number" },
        "solid": { "type": "array", "items": { "type": "boolean" } },
        "elevation": { "type": "array", "items": { "type": "number" } },
        "nav_zone": { "type": "array", "items": { "type": "integer" } },
        "light_probe": { "type": "array", "items": { "type": "number" } }
      }
    },
    "weather": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "type": { "type": "string" },
        "emitter": { "$ref": "#/definitions/emitter_config_2d" },
        "ambient_override": { "$ref": "#/definitions/color4" },
        "fog_density": { "type": "number" },
        "fog_color": { "$ref": "#/definitions/color3" },
        "transition_speed": { "type": "number" }
      }
    },
    "day_night": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "cycle_speed": { "type": "number" },
        "initial_time": { "type": "number" },
        "keyframes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "time": { "type": "number" },
              "ambient": { "$ref": "#/definitions/color4" },
              "torch_intensity": { "type": "number" }
            }
          }
        }
      }
    },
    "background_layer": {
      "type": "object",
      "properties": {
        "texture": { "type": "string" },
        "z": { "type": "number" },
        "parallax_factor": { "type": "number" },
        "quad_width": { "type": "number" },
        "quad_height": { "type": "number" },
        "uv_repeat_x": { "type": "number" },
        "uv_repeat_y": { "type": "number" },
        "tint": { "$ref": "#/definitions/color4" },
        "wall": { "type": "boolean" },
        "wall_y_offset": { "type": "number" }
      }
    },
    "emitter_config_2d": {
      "type": "object",
      "properties": {
        "spawn_rate": { "type": "number" },
        "particle_lifetime_min": { "type": "number" },
        "particle_lifetime_max": { "type": "number" },
        "velocity_min": { "$ref": "#/definitions/vec2" },
        "velocity_max": { "$ref": "#/definitions/vec2" },
        "acceleration": { "$ref": "#/definitions/vec2" },
        "size_min": { "type": "number" },
        "size_max": { "type": "number" },
        "size_end_scale": { "type": "number" },
        "color_start": { "$ref": "#/definitions/color4" },
        "color_end": { "$ref": "#/definitions/color4" },
        "tile": { "type": "string" },
        "z": { "type": "number" },
        "spawn_offset_min": { "$ref": "#/definitions/vec2" },
        "spawn_offset_max": { "$ref": "#/definitions/vec2" }
      }
    }
  }
}
