{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/eccyan/GSeurat/schemas/vfx.schema.json",
  "title": "GSeurat VFX Prefab",
  "description": "VFX prefab composing geometry, emitters, animations, and lights with relative positioning",
  "type": "object",
  "required": ["name", "elements"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name for the VFX prefab"
    },
    "duration": {
      "type": "number",
      "minimum": 0,
      "description": "Override max duration. If omitted, derived from max(element.start + element.duration)."
    },
    "category": {
      "type": "string",
      "description": "Library category (e.g., 'environmental', 'combat', 'ambient')"
    },
    "elements": {
      "type": "array",
      "items": { "$ref": "#/definitions/element" },
      "description": "Positioned components of the prefab"
    },
    "layers": {
      "type": "array",
      "description": "Deprecated v1 format — migrated to elements on import"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "element": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Display name"
        },
        "type": {
          "type": "string",
          "enum": ["object", "emitter", "animation", "light"],
          "description": "Element type"
        },
        "position": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3,
          "description": "Position relative to prefab origin [x, y, z]"
        },
        "start": {
          "type": "number",
          "minimum": 0,
          "description": "Start time in seconds (for timeline effects)"
        },
        "duration": {
          "type": "number",
          "minimum": 0,
          "description": "Duration of one cycle in seconds"
        },
        "loop": {
          "type": "boolean",
          "description": "true = repeats after duration. For continuous effects."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Free-form tags for organization"
        },
        "ply_file": {
          "type": "string",
          "description": "PLY file path relative to the .vfx.json file (type=object)"
        },
        "scale": {
          "type": "number",
          "minimum": 0,
          "description": "Scale factor for PLY geometry (type=object)"
        },
        "region": {
          "type": "object",
          "description": "Animation region shape (type=animation)",
          "properties": {
            "shape": {
              "type": "string",
              "enum": ["sphere", "box"]
            },
            "radius": {
              "type": "number",
              "minimum": 0,
              "description": "Sphere radius"
            },
            "half_extents": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 3,
              "maxItems": 3,
              "description": "Box half-extents [x, y, z]"
            }
          }
        },
        "emitter": {
          "type": "object",
          "description": "Particle emitter config (type=emitter)",
          "properties": {
            "preset": { "type": "string" },
            "spawn_rate": { "type": "number", "minimum": 0 },
            "lifetime_min": { "type": "number", "minimum": 0 },
            "lifetime_max": { "type": "number", "minimum": 0 },
            "velocity_min": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
            "velocity_max": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
            "acceleration": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
            "color_start": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
            "color_end": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
            "scale_min": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
            "scale_max": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
            "scale_end_factor": { "type": "number" },
            "opacity_start": { "type": "number", "minimum": 0, "maximum": 1 },
            "opacity_end": { "type": "number", "minimum": 0, "maximum": 1 },
            "emission": { "type": "number", "minimum": 0 },
            "spawn_offset_min": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
            "spawn_offset_max": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
            "burst_duration": { "type": "number", "minimum": 0 },
            "spline": {
              "type": "object",
              "description": "Optional spline path for emitter movement or particle flight",
              "required": ["mode", "control_points"],
              "properties": {
                "mode": { "type": "string", "enum": ["emitter_path", "particle_path"] },
                "control_points": {
                  "type": "array",
                  "items": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
                  "minItems": 2,
                  "description": "3D control points in local space (minimum 2)"
                },
                "emitter_speed": { "type": "number", "minimum": 0, "description": "Cycles/sec along spline (emitter_path)" },
                "path_spread": { "type": "number", "minimum": 0, "description": "Lateral offset from spline (particle_path)" },
                "align_to_tangent": { "type": "boolean", "description": "Orient particles along spline tangent" }
              },
              "additionalProperties": false
            }
          }
        },
        "animation": {
          "type": "object",
          "description": "GS animation config (type=animation)",
          "required": ["effect"],
          "properties": {
            "effect": {
              "type": "string",
              "enum": ["detach", "float", "orbit", "dissolve", "reform", "pulse", "vortex", "wave", "scatter"]
            },
            "params": {
              "type": "object",
              "properties": {
                "rotations": { "type": "number" },
                "rotations_easing": { "type": "string" },
                "expansion": { "type": "number" },
                "expansion_easing": { "type": "string" },
                "height_rise": { "type": "number" },
                "height_easing": { "type": "string" },
                "opacity_end": { "type": "number", "minimum": 0, "maximum": 1 },
                "opacity_easing": { "type": "string" },
                "scale_end": { "type": "number", "minimum": 0, "maximum": 1 },
                "scale_easing": { "type": "string" },
                "velocity": { "type": "number" },
                "gravity": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
                "noise": { "type": "number" },
                "wave_speed": { "type": "number" },
                "pulse_frequency": { "type": "number" }
              }
            },
            "reform": {
              "type": "object",
              "properties": {
                "lifetime": { "type": "number", "minimum": 0 }
              }
            }
          }
        },
        "light": {
          "type": "object",
          "description": "Light config (type=light)",
          "required": ["color", "intensity", "radius"],
          "properties": {
            "color": { "type": "array", "items": { "type": "number", "minimum": 0, "maximum": 1 }, "minItems": 3, "maxItems": 3 },
            "intensity": { "type": "number", "minimum": 0 },
            "radius": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
